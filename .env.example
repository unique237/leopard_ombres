# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Render, Railway, Neon, local Docker, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# Secret used to sign admin JWT tokens — use a long random string
JWT_SECRET=

# ── Optional / legacy ─────────────────────────────────────────────────────────
# These were used when the project ran on Supabase.
# The server now connects directly to PostgreSQL — leave blank if not using Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
